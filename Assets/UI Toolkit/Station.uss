Label {
    margin: 0;
    padding: 0;
}

.left {
    rotate: -135deg;
    translate: 0 -2px;
}

.board {
    width: 32%;
}

.bg-accent {
    background-color: var(--accent);
}

.station {
    border-color: var(--accent);
    width: 12px;
    height: 12px;
    border-radius: 6px;
    border-width: 3px;
}

.inactive {
    background-color: rgb(140, 140, 140);
    border-color: rgb(140, 140, 140);
}

.line {
    width: 56px;
    height: 3px;
    scale: 1.1 1;
}
