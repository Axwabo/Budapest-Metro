#Content > * {
    flex-grow: 1;
    flex-direction: row;
}

Label {
    margin-top: 0;
    margin-right: 0;
    margin-bottom: 0;
    margin-left: 0;
    padding-top: 0;
    padding-right: 0;
    padding-bottom: 0;
    padding-left: 0;
}

.icon {
    margin-right: 50px;
    margin-left: 50px;
}

#Transfers Label {
    word-spacing: 15px;
}
